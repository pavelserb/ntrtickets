# ── Biļešu Serviss (API credentials) ──
BILESU_SERVISS_EMAIL=your_email@example.com
BILESU_SERVISS_PASSWORD=your_password

# ── mticket (database connection) ──
MTICKET_DB_HOST=your_db_host
MTICKET_DB_PORT=3306
MTICKET_DB_USER=your_db_user
MTICKET_DB_PASSWORD=your_db_password
MTICKET_DB_NAME=your_db_name

# ── Passo (Power BI Report Server, NTLM auth) ──
PASSO_USERNAME=your_username
PASSO_PASSWORD=your_password

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
